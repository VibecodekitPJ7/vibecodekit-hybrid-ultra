      "/vibe-vision",
      "/vibe-rri",
      "/vibe-rri-t",
      "/vibe-rri-ux",
      "/vibe-rri-ui",
      "/vck-cso",
      "/vck-review",
      "/vck-qa",
      "/vck-qa-only",
      "/vck-ship",
      "/vck-investigate",
      "/vck-canary",
      "/vck-office-hours",
      "/vck-ceo-review",
      "/vck-eng-review",
      "/vck-design-consultation",
      "/vck-design-review",
      "/vck-learn",
      "/vck-retro",
      "/vck-second-opinion",
      "/vck-pipeline"
    ],
    "paths": [
      "**/.vibecode/**",
      "**/.claw/**",
      "**/.claw.json",
      "**/SKILL.md",
      "**/CLAUDE.md",
      "**/manifest.llm.json",
