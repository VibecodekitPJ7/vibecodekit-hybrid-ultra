{
  "name": "dashboard",
  "description": "Admin dashboard with KPI cards and chart placeholder",
  "stacks": {
    "nextjs": {
      "files": [
        "package.json",
        "README.md",
        "app/page.tsx",
        "app/layout.tsx",
        "tailwind.config.ts",
        "postcss.config.js",
        "app/globals.css",
        "next.config.ts",
        "vercel.json",
        "tsconfig.json",
        ".gitignore",
        ".env.example",
        "design/tokens.json",
        "design/tokens.css",
        "lib/cn.ts",
        "components/ui/button.tsx",
        "components/ui/input.tsx",
        "components/ui/card.tsx"
      ],
      "post_install": [
        "npm install",
        "npm run dev"
      ],
      "success_criteria": [
        "package.json exists",
        "app/page.tsx exists",
        "package.json has 'next' in dependencies",
        "package.json has 'recharts' in dependencies",
        "tailwind.config.ts exists",
        "postcss.config.js exists",
        "app/globals.css exists",
        "package.json has 'tailwindcss' in devDependencies",
        "next.config.ts exists",
        "vercel.json exists",
        "tsconfig.json exists",
        ".gitignore exists",
        ".env.example exists",
        "design/tokens.json exists",
        "design/tokens.css exists",
        "lib/cn.ts exists",
        "components/ui/button.tsx exists",
        "components/ui/input.tsx exists",
        "components/ui/card.tsx exists",
        "package.json has 'clsx' in dependencies",
        "package.json has 'tailwind-merge' in dependencies"
      ]
    }
  }
}
